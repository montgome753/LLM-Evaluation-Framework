# ============================================================
# LLM Evaluation Framework — Environment Variables
# Copy this file to .env and fill in your API keys.
# ============================================================

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Anthropic (Claude) ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Google (Gemini) ──────────────────────────────────────────
GEMINI_API_KEY=AI...
GOOGLE_API_KEY=AI...

# ── Mistral ──────────────────────────────────────────────────
MISTRAL_API_KEY=...

# ── Together AI (Llama) ──────────────────────────────────────
TOGETHERAI_API_KEY=...

# ── Cohere ───────────────────────────────────────────────────
COHERE_API_KEY=...

# ── HuggingFace (for dataset loading) ────────────────────────
HUGGINGFACE_TOKEN=hf_...

# ── App Settings ─────────────────────────────────────────────
# SQLite DB path (default: llm_eval.db in current directory)
LLM_EVAL_DB_PATH=llm_eval.db

# Default benchmark cache directory
LLM_EVAL_CACHE_DIR=~/.cache/llm_eval

# FastAPI server
HOST=0.0.0.0
PORT=8000

# Streamlit dashboard port
DASHBOARD_PORT=8501

# LiteLLM verbose logging (set to "true" for debug)
LITELLM_VERBOSE=false
